flowchart LR

    %% ─────────────────────────────────────────
    %% STAGE 1 — Data Extraction & Merging
    %% ─────────────────────────────────────────
    subgraph DataPrep["① Data Extraction & Merging  (DataPrep)"]
        direction TB
        D1["D1 · Contract Core"]
        D2["D2 · Financial Data"]
        D3["D3 · ESG Data"]
        D4["D4 · Logistics / Macro"]
        D5["D5 · Market Analytics"]
        D6["D6 · News Sentiment"]
        FE["Feature Engineering\n& Merging"]
        D1 & D2 & D3 & D4 & D5 & D6 --> FE
    end

    FE -. "FeatureMatrix" .-> WeakSup
    FE -. "FeatureMatrix" .-> Stage1Tr

    %% ─────────────────────────────────────────
    %% STAGE 2 — Weak Supervision
    %% ─────────────────────────────────────────
    subgraph WeakSup["② Weak Supervision  (WeakSup · Snorkel)"]
        direction TB
        LF{{"Domain-driven\nLabeling Functions"}}
        SLM(["Snorkel Label Model"])
        PROB[/"Probabilistic Label\nrenegotiation_prob"/]
        LF --> SLM --> PROB
    end

    PROB -. "Weak Labels" .-> Stage1Tr

    %% ─────────────────────────────────────────
    %% STAGE 3 — Representation Learning
    %% ─────────────────────────────────────────
    GOLD["🏷 Gold Labels\n(GoldInput)"]
    GOLD --> Stage1Tr

    subgraph Stage1Tr["③ Stage 1 — Representation Learning  (Stage1Tr)"]
        direction TB

        subgraph Cond["Training Conditions"]
            WA["WA · Weak-only"]
            BB["BB · Gold-only"]
            WC["WC · Hybrid"]
        end

        subgraph Mdl["Model Variants"]
            XGB["XGBoost"]
            EN["Elastic Net"]
            MLP["MLP Neural Net"]
        end

        WT["Weights Transfer"]
        PW[/"Pretrained MLP\n(MLPWeights)"/]

        WA & BB & WC --> XGB & EN & MLP
        MLP ==>|"Best weights\n(bold transfer)"| WT --> PW
    end

    PW --> Stage2Tr

    %% ─────────────────────────────────────────
    %% STAGE 4 — Meta-Learning (MAML)
    %% ─────────────────────────────────────────
    subgraph Stage2Tr["④ Stage 2 — Meta-Learning  (Stage2Tr · MAML)"]
        direction TB
        NS{{"Dept-based\nN-way K-shot Sampler"}}
        MAML(["MAML Inner / Outer\nLoop Optimisation"])
        OUT[/"Robust Predictions\nfor Unseen Departments\n(FinalOutput)"/]
        NS --> MAML --> OUT
    end

    %% ─────────────────────────────────────────
    %% Styling
    %% ─────────────────────────────────────────
    classDef source    fill:#F5F5F5,stroke:#9E9E9E,color:#212121
    classDef process   fill:#E3F2FD,stroke:#1565C0,color:#0D2B6E
    classDef decision  fill:#FFF9C4,stroke:#F9A825,color:#4E342E
    classDef output    fill:#EDE7F6,stroke:#6A1B9A,color:#311B92
    classDef transfer  fill:#E8F5E9,stroke:#2E7D32,color:#1B5E20
    classDef gold      fill:#FFF8E1,stroke:#FF8F00,color:#3E2723

    class D1,D2,D3,D4,D5,D6 source
    class FE,SLM,MAML process
    class LF,NS decision
    class PROB,OUT output
    class XGB,EN,MLP,WA,BB,WC,WT,PW transfer
    class GOLD gold
